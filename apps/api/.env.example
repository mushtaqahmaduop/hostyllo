# HOSTYLLO API — environment template (audit C3).
# Copy to `.env` and fill with real values. NEVER commit the real `.env` (it is git-ignored).
# Production secrets belong in the Railway/Vercel secret store, NOT in a file on disk.
#
# ⚠️ ROTATE-FIRST: any credential that has ever lived in a working-tree `.env` (JWT private
#    key, Supabase service key, DB password, Resend key, Upstash token) is considered exposed
#    and MUST be rotated before launch.

# ── JWT (RS256) — generate: openssl genrsa -out priv.pem 2048 && openssl rsa -in priv.pem -pubout ──
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# ── Runtime ──
NODE_ENV="development"          # "production" only on the real deploy
PORT=3001
CORS_ORIGIN="http://localhost:3000"
COOKIE_SECRET=""               # required in production — `openssl rand -hex 32`

# ── Crypto — MUST be 32 random bytes; validated at boot (see lib/env.ts). ──
ENCRYPTION_KEY=""              # `openssl rand -hex 32` — never a placeholder/pattern

# ── Postgres (Supabase) ──
# Privileged/system connection (auth bootstrap + workers). Cross-tenant by design.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
# Per-request tenant connection — the least-privilege hostyllo_app role from migration 010.
# When set, withTenant() runs under FORCE RLS (fail-closed isolation). Leave empty in dev.
DATABASE_URL_APP=""
# Optional: pin the provider CA (PEM) instead of trusting the system store (see lib/db.ts).
DATABASE_CA_CERT=""

# ── Supabase Management API (for scripts/verify-pitr.sh) — a Personal Access Token, NOT the
#    service_role key. Create at https://supabase.com/dashboard/account/tokens ──
SUPABASE_URL="https://YOUR_REF.supabase.co"
SUPABASE_ACCESS_TOKEN=""
SUPABASE_SERVICE_KEY=""        # data-plane only; never use for the Management API

# ── Redis (TCP, e.g. Railway Redis) — used by both the app cache/session and BullMQ ──
REDIS_URL="redis://default:PASSWORD@HOST:6379"

# ── Email (Resend) ──
RESEND_API_KEY=""
EMAIL_FROM="HOSTYLLO <noreply@hostyllo.app>"

# ── Observability ──
SENTRY_DSN=""
